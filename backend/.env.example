# MongoDB connection for your local or deployed backend
MONGO_URI=mongodb+srv://<username>:<password>@cluster-url/my-db
PORT=8001

# Gmail SMTP settings for sending OTP emails
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_SERVICE=gmail
# optional if you want custom host/port
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
